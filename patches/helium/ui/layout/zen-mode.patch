+
+bool BrowserView::IsPointInZenTopTrigger(const gfx::Point& point) const {
+  return point.y() >= 0 && point.y() < kZenModeRevealTriggerThickness;
+}
+
+bool BrowserView::IsPointInZenSideTrigger(const gfx::Point& point) const {
+  if (!ShouldDrawVerticalTabStrip()) {
+    return false;
+  }
+  auto* controller = tabs::VerticalTabStripStateController::From(browser_);
+  const bool right_aligned = controller && controller->IsTabStripRightAligned();
+  if (right_aligned) {
+    return point.x() >= width() - kZenModeRevealTriggerThickness &&
+           point.x() < width();
+  }
+  return point.x() >= 0 && point.x() < kZenModeRevealTriggerThickness;
+}
