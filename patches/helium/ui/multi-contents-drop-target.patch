+      side_, use_system_top_corner_, use_system_bottom_corner_);
+  if (inner_container_) {
+    SetInnerContainerBackground(inner_container_, radii);
+  }
+  if (outline_) {
+    outline_->SetCornerRadii(radii);
+  }
