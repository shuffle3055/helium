+gfx::Insets GetOuterContainerMargins(
+    const std::optional<MultiContentsDropTargetView::DropSide>& side,
+    bool side_chrome_attached,
+    bool use_content_edge_margin) {
+  if (!side.has_value()) {
+    return gfx::Insets::TLBR(0, kOuterPadding, kOuterPadding, kOuterPadding);
+  }
+
+  const int chrome_edge_margin = side_chrome_attached ? 0 : kOuterPadding;
+  const int content_edge_margin =
+      use_content_edge_margin ? kOuterPadding : 0;
+  const bool is_start = side == MultiContentsDropTargetView::DropSide::START;
+  return gfx::Insets::TLBR(0, is_start ? chrome_edge_margin
+                                       : content_edge_margin,
+                           kOuterPadding,
+                           is_start ? content_edge_margin
+                                    : chrome_edge_margin);
+}
+
+gfx::RoundedCornersF GetInnerContainerRadii(
+    const std::optional<MultiContentsDropTargetView::DropSide>& side,
+    bool use_system_top_corner,
+    bool use_system_bottom_corner) {
+  const bool is_start = side == MultiContentsDropTargetView::DropSide::START;
+  const bool is_end = side == MultiContentsDropTargetView::DropSide::END;
+  const int generic_radius = GetGenericFrameRadius();
+  const float system_radius = GetPaddedFrameRadius();
+
+  return gfx::RoundedCornersF(
+      is_start && use_system_top_corner ? system_radius : generic_radius,
+      is_end && use_system_top_corner ? system_radius : generic_radius,
+      is_end && use_system_bottom_corner ? system_radius : generic_radius,
+      is_start && use_system_bottom_corner ? system_radius
+                                           : generic_radius);
+}
+
+void SetInnerContainerBackground(
